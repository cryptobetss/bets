# ─── Server ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Session ──────────────────────────────────────────────────────────
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# ─── Admin password ───────────────────────────────────────────────────
# Generate hash: npm run gen-hash
# Then paste the output here.
# Default below = "admin123" — CHANGE THIS before deploying!
ADMIN_PASSWORD_HASH=$2b$12$lr1aH5AOZzR/0AkjZXSgBOnd61GWz7VMgGZq.ck0iUaSNIp5KMs0a
